  "bugs": {
    "url": "https://github.com/longbai203-del/auto-wash-manager-saas/issues"
  },
  "homepage": "https://github.com/longbai203-del/auto-wash-manager-saas#readme",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3"
  }
}
